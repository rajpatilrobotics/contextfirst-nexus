# Live analysis stays disabled for the public demo unless a later approved deployment changes it.
ENABLE_LIVE_ANALYSIS=false
NEXT_PUBLIC_ENABLE_LIVE_ANALYSIS=false
NEXT_PUBLIC_ENABLE_DEMO_REPLAY=true

# OpenAI frozen release: openai-quality-v1 / gpt-5.6-sol / reasoning effort medium.
ENABLE_OPENAI_ANALYSIS=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
OPENAI_REASONING_EFFORT=medium

# Google Gemini frozen release: gemini-quality-v1 / gemini-3.5-flash / unpaid synthetic-only tier.
ENABLE_GEMINI_ANALYSIS=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_SERVICE_TIER=unpaid

# Mistral frozen release: mistral-small-free-v1 / mistral-small-2603 / unpaid synthetic-only tier.
ENABLE_MISTRAL_ANALYSIS=false
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-2603
MISTRAL_SERVICE_TIER=unpaid
MISTRAL_REASONING_EFFORT=medium
